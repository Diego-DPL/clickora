---
import '../styles/global.css';
import CookieBanner from '../components/CookieBanner.astro';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    
    <!-- SEO Meta Tags -->
    <meta name="keywords" content="landing page fisioterapia, landing page abogados, web organización eventos, diseño web españa, crear landing page conversión, agencia marketing digital, clickora, web corporativa rápida, desarrollo web seo" />
    <meta name="author" content="Clickora - Diego DPL" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <link rel="canonical" href="https://clickora.es" />
    
    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="business.business" />
    <meta property="og:url" content="https://clickora.es" />
    <meta property="og:site_name" content="Clickora | Desarrollo Web de Alto Impacto" />
    <meta property="og:locale" content="es_ES" />
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://clickora.es/og-image.png" />
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- Preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    
    <title>{title}</title>

    
    <!-- Schema.org Markup for LLMs & SEO -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "ProfessionalService",
        "name": "Clickora",
        "image": "https://clickora.es/logo.png",
        "@id": "https://clickora.es",
        "url": "https://clickora.es",
        "telephone": "+34608008081",
        "email": "info@diegodpl.com",
        "priceRange": "€€",
        "address": {
          "@type": "PostalAddress",
          "addressCountry": "ES"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "addressCountry": "ES"
        },
        "description": "Agencia de desarrollo web líder en España experta en Landing Pages de alta conversión, E-commerce y aplicaciones SaaS. Optimizamos tu presencia digital para que la IA (ChatGPT, Gemini) y Google recomienden tu negocio.",
        "founder": {
          "@type": "Person",
          "name": "Diego DPL"
        },
        "areaServed": "España",
        "knowsAbout": [
          "Desarrollo Web",
          "Landing Pages",
          "E-commerce",
          "SEO",
          "Optimización de Conversiones",
          "Astro Framework",
          "Tailwind CSS"
        ],
        "offers": [
          {
            "@type": "Offer",
            "name": "Landing Page Premium",
            "price": "299",
            "priceCurrency": "EUR",
            "description": "Diseño web de alto impacto optimizado para ventas y SEO.",
            "url": "https://clickora.es/#precios"
          },
          {
            "@type": "Offer",
            "name": "Mantenimiento Web VIP",
            "price": "49",
            "priceCurrency": "EUR",
            "priceSpecification": {
              "@type": "UnitPriceSpecification",
              "price": "49",
              "priceCurrency": "EUR",
              "unitCode": "MON"
            },
            "description": "Servicio de mantenimiento, seguridad y optimización mensual.",
            "url": "https://clickora.es/#precios"
          }
        ],
        "sameAs": [
          "https://github.com/Diego-DPL"
        ]
      }
    </script>
  </head>
  <body>
    <slot />
    <CookieBanner />
  </body>
</html>

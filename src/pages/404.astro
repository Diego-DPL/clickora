---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="404 — Página no encontrada | Clickora"
  description="Esta página no existe. Vuelve al inicio de Clickora."
>
  <Navbar />

  <main class="bg-ivory min-h-screen flex flex-col items-center justify-center px-8 py-40 relative overflow-hidden">

    <!-- Giant 404 watermark -->
    <p
      class="font-display italic font-black select-none pointer-events-none absolute inset-0 flex items-center justify-center text-[clamp(12rem,_40vw,_36rem)] leading-none"
      style="color: rgba(15,15,15,0.04)"
      aria-hidden="true"
    >
      404
    </p>

    <!-- Content -->
    <div class="relative z-10 text-center max-w-xl">

      <p class="label text-muted mb-6">Error 404</p>

      <h1 class="font-display italic font-black text-[clamp(2.5rem,_7vw,_5.5rem)] text-ink leading-[0.93] mb-6">
        Esta página<br>
        <span class="text-blue">no existe.</span>
      </h1>

      <p class="text-muted text-base leading-relaxed mb-10 max-w-sm mx-auto">
        Puede que la URL esté mal escrita o que la página haya sido eliminada. Sin drama — el inicio está a un clic.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/" class="btn-primary">
          ← Volver al inicio
        </a>
        <a
          href="https://wa.me/34608008081?text=Hola,%20he%20encontrado%20un%20error%20en%20la%20web"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-outline"
        >
          Reportar error
        </a>
      </div>

    </div>

  </main>

  <Footer />
</Layout>

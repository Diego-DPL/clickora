---
const services = [
  {
    icon: '🛒',
    title: 'E-commerce',
    description: 'Tiendas online que venden. Gestión de productos, pagos seguros y experiencia de compra optimizada.',
    features: ['Carrito inteligente', 'Pagos integrados', 'Panel de admin', 'Analytics'],
    color: 'from-blue-500 to-cyan-500'
  },
  {
    icon: '🚀',
    title: 'Landing Pages',
    description: 'Páginas diseñadas para convertir visitantes en clientes. Rápidas, persuasivas y optimizadas para SEO.',
    features: ['Diseño persuasivo', 'Carga ultrarrápida', 'SEO optimizado', 'A/B Testing'],
    color: 'from-purple-500 to-pink-500'
  },
  {
    icon: '💼',
    title: 'SaaS & Apps Web',
    description: 'Aplicaciones web escalables y seguras. Desde MVP hasta plataformas complejas.',
    features: ['Arquitectura escalable', 'API REST', 'Autenticación', 'Dashboard'],
    color: 'from-orange-500 to-red-500'
  }
];
---

<section id="servicios" class="relative py-20 md:py-32 overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0 bg-slate-950"></div>
  <div class="absolute top-0 left-1/2 w-[500px] h-[500px] bg-brand-500/5 rounded-full blur-3xl transform -translate-x-1/2"></div>
  
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-16 space-y-4">
      <span class="inline-block px-4 py-2 rounded-full glass border border-brand-500/20 text-sm text-brand-400 font-semibold">
        Servicios
      </span>
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-white">
        Lo que <span class="gradient-text">hacemos mejor</span>
      </h2>
      <p class="max-w-2xl mx-auto text-lg text-slate-400">
        Creamos productos digitales que no solo se ven bien, sino que generan resultados medibles
      </p>
    </div>
    
    <!-- Services Grid -->
    <div class="grid md:grid-cols-3 gap-8">
      {services.map((service, index) => (
        <div 
          class="group relative p-8 rounded-2xl glass border border-slate-800 hover:border-brand-500/50 transition-all duration-500 transform hover:-translate-y-2"
          style={`animation: fadeInUp 0.8s ease-out ${index * 0.2}s forwards; opacity: 0;`}
        >
          <!-- Glow Effect -->
          <div class={`absolute inset-0 rounded-2xl bg-gradient-to-br ${service.color} opacity-0 group-hover:opacity-10 transition-opacity duration-500 blur-xl`}></div>
          
          <!-- Content -->
          <div class="relative z-10 space-y-6">
            <!-- Icon -->
            <div class={`w-16 h-16 rounded-xl bg-gradient-to-br ${service.color} flex items-center justify-center text-3xl transform group-hover:scale-110 group-hover:rotate-6 transition-all duration-300`}>
              {service.icon}
            </div>
            
            <!-- Title & Description -->
            <div class="space-y-3">
              <h3 class="text-2xl font-bold text-white group-hover:text-brand-400 transition-colors">
                {service.title}
              </h3>
              <p class="text-slate-400 leading-relaxed">
                {service.description}
              </p>
            </div>
            
            <!-- Features -->
            <ul class="space-y-2 pt-4 border-t border-slate-800">
              {service.features.map(feature => (
                <li class="flex items-center gap-2 text-sm text-slate-300">
                  <svg class="w-5 h-5 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                  </svg>
                  <span>{feature}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

---
const projects = [
  {
    index: "01",
    title: "Clínica de Fisioterapia",
    result: "+120%",
    unit: "citas online",
    desc: "Web enfocada en reservas automáticas y posicionamiento local. Agenda llena desde el primer mes.",
    tags: ["Reservas", "SEO Local", "Google Maps"],
    before: "Gestión manual por teléfono",
    after: "Agenda llena automatizada"
  },
  {
    index: "02",
    title: "Consulta de Psicología",
    result: "+7",
    unit: "pacientes nuevos/mes",
    desc: "Landing page empática y profesional que redujo el costo por lead un 50%.",
    tags: ["Google Ads", "Diseño Limpio", "Confianza"],
    before: "Web obsoleta y lenta",
    after: "Coste por lead ↓ 50%"
  },
  {
    index: "03",
    title: "Organización de Eventos",
    result: "×4",
    unit: "presupuestos de bodas",
    desc: "Portafolio visual de alto impacto que multiplicó por cuatro las solicitudes de presupuesto.",
    tags: ["Galería", "Video", "Social Ads"],
    before: "PDF enviado por email",
    after: "Web visual que convierte"
  }
];
---

<section id="ejemplos" class="bg-ink py-24 md:py-36 overflow-hidden">
  <div class="max-w-[1600px] mx-auto px-6 md:px-10 lg:px-16">

    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-16 md:mb-24">
      <div>
        <p class="label text-muted mb-4 reveal-fast">Trabajo reciente</p>
        <h2 class="heading-display font-serif text-[clamp(2.5rem,_6vw,_5.5rem)] text-parchment reveal" style="transition-delay:0.1s">
          Resultados<br>
          <em class="text-lime not-italic">reales.</em>
        </h2>
      </div>
      <p class="text-muted text-sm max-w-xs leading-relaxed reveal-fast" style="transition-delay:0.2s">
        No solo diseñamos webs bonitas. Creamos herramientas de venta que funcionan desde el primer día.
      </p>
    </div>

    <!-- Projects list -->
    <div class="divide-subtle">
      {projects.map((project, i) => (
        <div
          class={`group grid grid-cols-1 md:grid-cols-12 gap-6 md:gap-0 py-10 md:py-14 border-t border-subtle hover:bg-ink2 transition-colors duration-300 px-4 md:px-8 -mx-4 md:-mx-8 reveal`}
          style={`transition-delay:${i * 0.12}s`}
        >
          <!-- Index -->
          <div class="md:col-span-1 flex items-start">
            <span class="label text-muted">{project.index}</span>
          </div>

          <!-- Title + tags -->
          <div class="md:col-span-4 md:pl-4">
            <h3 class="font-serif text-2xl md:text-3xl text-parchment mb-4 group-hover:text-lime transition-colors duration-300">
              {project.title}
            </h3>
            <div class="flex flex-wrap gap-2">
              {project.tags.map(tag => (
                <span class="label text-muted border border-subtle px-3 py-1">
                  {tag}
                </span>
              ))}
            </div>
          </div>

          <!-- Description -->
          <div class="md:col-span-4 md:pl-8">
            <p class="text-muted text-sm leading-relaxed mb-6">{project.desc}</p>
            <div class="grid grid-cols-2 gap-4 text-sm">
              <div>
                <span class="label text-muted block mb-1">Antes</span>
                <span class="text-parchment/60">{project.before}</span>
              </div>
              <div>
                <span class="label text-lime block mb-1">Después</span>
                <span class="text-parchment">{project.after}</span>
              </div>
            </div>
          </div>

          <!-- Result -->
          <div class="md:col-span-3 flex items-center justify-start md:justify-end">
            <div class="text-right">
              <div class="font-serif text-[clamp(3rem,_6vw,_5rem)] text-lime leading-none group-hover:scale-105 transition-transform duration-300 origin-right">
                {project.result}
              </div>
              <div class="label text-muted mt-1">{project.unit}</div>
            </div>
          </div>
        </div>
      ))}
      <div class="border-t border-subtle"></div>
    </div>

  </div>
</section>

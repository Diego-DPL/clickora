---
---

<header id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500">
  <div class="flex items-center justify-between px-6 md:px-10 h-16 md:h-20">

    <!-- Logo -->
    <a href="#hero" class="font-sans font-bold text-xl md:text-2xl text-ink hover:text-blue transition-colors duration-300 tracking-tight">
      Clickora<span class="text-blue">™</span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-10">
      <a href="#servicios" class="label text-muted hover:text-ink transition-colors duration-200">Servicios</a>
      <a href="#ventajas"  class="label text-muted hover:text-ink transition-colors duration-200">Ventajas</a>
      <a href="#precios"   class="label text-muted hover:text-ink transition-colors duration-200">Precios</a>
      <a
        href="https://wa.me/34608008081?text=Hola,%20quiero%20una%20propuesta%20para%20mi%20web"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary text-xs"
      >
        Hablemos ↗
      </a>
    </nav>

    <!-- Mobile toggle -->
    <button id="nav-toggle" class="md:hidden flex flex-col gap-1.5 p-2" aria-label="Menú">
      <span class="block w-6 h-0.5 bg-ink transition-all duration-300"></span>
      <span class="block w-6 h-0.5 bg-ink transition-all duration-300"></span>
      <span class="block w-4 h-0.5 bg-ink transition-all duration-300"></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="nav-mobile" class="hidden md:hidden bg-ivory border-t border-soft">
    <nav class="flex flex-col px-6 py-6 gap-5">
      <a href="#servicios" class="label text-muted hover:text-blue transition-colors" data-mobile-link>Servicios</a>
      <a href="#ventajas"  class="label text-muted hover:text-blue transition-colors" data-mobile-link>Ventajas</a>
      <a href="#precios"   class="label text-muted hover:text-blue transition-colors" data-mobile-link>Precios</a>
      <a
        href="https://wa.me/34608008081?text=Hola,%20quiero%20una%20propuesta%20para%20mi%20web"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary w-max"
        data-mobile-link
      >
        Hablemos ↗
      </a>
    </nav>
  </div>
</header>

<script>
  const navbar = document.getElementById('navbar');
  const toggle = document.getElementById('nav-toggle');
  const mobileMenu = document.getElementById('nav-mobile');

  const updateNav = () => {
    if (window.scrollY > 40) {
      navbar?.classList.add('bg-ivory/90', 'backdrop-blur-md', 'border-b', 'border-soft');
    } else {
      navbar?.classList.remove('bg-ivory/90', 'backdrop-blur-md', 'border-b', 'border-soft');
    }
  };
  window.addEventListener('scroll', updateNav, { passive: true });
  updateNav();

  toggle?.addEventListener('click', () => mobileMenu?.classList.toggle('hidden'));
  document.querySelectorAll('[data-mobile-link]').forEach(l => l.addEventListener('click', () => mobileMenu?.classList.add('hidden')));
</script>

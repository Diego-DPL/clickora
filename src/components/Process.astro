---
const steps = [
  {
    number: "01",
    title: "Diagnóstico Express",
    desc: "Analizamos tu oferta y tu cliente ideal en una llamada de 15 minutos. Sin compromiso, sin rollos."
  },
  {
    number: "02",
    title: "Propuesta & Estrategia",
    desc: "Diseñamos la estructura, el copy y la interfaz pensando únicamente en la conversión."
  },
  {
    number: "03",
    title: "Entrega + Medición",
    desc: "Tu web lista con Pixel y Analytics configurados. Lanzas tus anuncios desde el día 1."
  }
];
---

<section id="proceso" class="bg-ink2 py-24 md:py-36 overflow-hidden">
  <div class="max-w-[1600px] mx-auto px-6 md:px-10 lg:px-16">

    <!-- Header -->
    <div class="mb-16 md:mb-24">
      <p class="label text-muted mb-4 reveal-fast">Proceso</p>
      <h2 class="heading-display font-serif text-[clamp(2.5rem,_6vw,_5.5rem)] text-parchment reveal" style="transition-delay:0.1s">
        Cómo <em class="text-lime not-italic">trabajamos.</em>
      </h2>
    </div>

    <!-- Steps -->
    <div class="grid md:grid-cols-3 gap-0 divide-subtle md:divide-y-0 md:divide-x-0">
      {steps.map((step, i) => (
        <div
          class={`group relative p-8 md:p-10 border border-subtle hover:bg-ink3 transition-colors duration-300 reveal`}
          style={`transition-delay:${i * 0.15}s`}
        >
          <!-- Big number -->
          <div class="font-serif text-[clamp(4rem,_10vw,_8rem)] text-lime/15 leading-none select-none absolute top-6 right-6 group-hover:text-lime/25 transition-colors duration-300">
            {step.number}
          </div>

          <div class="relative z-10">
            <p class="label text-lime mb-6">{step.number}</p>
            <h3 class="font-serif text-2xl md:text-3xl text-parchment mb-4 leading-tight">
              {step.title}
            </h3>
            <p class="text-muted text-sm leading-relaxed">
              {step.desc}
            </p>
          </div>
        </div>
      ))}
    </div>

    <!-- Guarantee -->
    <div class="mt-12 md:mt-16 flex flex-col md:flex-row items-start md:items-center gap-6 p-8 border border-subtle reveal" style="transition-delay:0.4s">
      <div class="w-12 h-12 border border-lime flex items-center justify-center flex-shrink-0">
        <svg class="w-5 h-5 text-lime" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
        </svg>
      </div>
      <div>
        <h4 class="text-parchment font-semibold mb-1">Garantía de satisfacción</h4>
        <p class="text-muted text-sm leading-relaxed max-w-2xl">
          Si en los primeros 7 días no te convence nuestra propuesta de diseño, hacemos una revisión completa o te devolvemos el dinero. Queremos que estés 100% seguro.
        </p>
      </div>
    </div>

  </div>
</section>

---
const benefits = [
  { title: "Diseño Estratégico",         desc: "Interfaces limpias y modernas que guían al usuario hacia la conversión." },
  { title: "Copy de Conversión",          desc: "Textos persuasivos que conectan con los problemas reales de tu cliente." },
  { title: "WhatsApp + Formulario",       desc: "Integraciones clave para que te contacten por su canal favorito." },
  { title: "Entrega Llave en Mano",       desc: "Tu web lista para vender. Sin configuraciones técnicas de tu parte." },
  { title: "Analítica Configurada",       desc: "Pixel de Facebook y Google Analytics 4 instalados y listos para tus campañas." },
  { title: "Velocidad Máxima",            desc: "Optimizada para Core Web Vitals. Google y tus usuarios lo notan." }
];
---

<section id="ventajas" class="bg-ink py-24 md:py-36 overflow-hidden">
  <div class="max-w-[1600px] mx-auto px-6 md:px-10 lg:px-16">

    <!-- Two-column editorial layout -->
    <div class="grid md:grid-cols-2 gap-16 md:gap-24 items-start">

      <!-- Left: headline + CTA -->
      <div class="md:sticky md:top-32">
        <p class="label text-muted mb-4 reveal-fast">Ventajas</p>
        <h2 class="heading-display font-serif text-[clamp(2.5rem,_6vw,_5.5rem)] text-parchment mb-8 reveal" style="transition-delay:0.1s">
          Por qué elegir<br>
          <em class="text-lime not-italic">Clickora.</em>
        </h2>
        <p class="text-muted text-sm leading-relaxed mb-10 max-w-sm reveal" style="transition-delay:0.2s">
          Cada detalle pensado para maximizar tus resultados desde el primer día.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 reveal" style="transition-delay:0.3s">
          <a
            href="https://wa.me/34608008081?text=Hola,%20quiero%20una%20consultoría%20gratuita"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-lime"
          >
            Consultoría gratis
          </a>
          <a href="mailto:info@diegodpl.com" class="btn-ghost">
            info@diegodpl.com
          </a>
        </div>
      </div>

      <!-- Right: benefits list -->
      <div class="divide-subtle">
        {benefits.map((b, i) => (
          <div
            class={`group flex items-start gap-6 py-8 border-t border-subtle reveal`}
            style={`transition-delay:${i * 0.08}s`}
          >
            <span class="font-serif text-4xl text-lime/20 leading-none group-hover:text-lime/60 transition-colors duration-300 select-none w-10 flex-shrink-0">
              {String(i + 1).padStart(2, '0')}
            </span>
            <div>
              <h3 class="text-parchment font-semibold text-base mb-2 group-hover:text-lime transition-colors duration-300">
                {b.title}
              </h3>
              <p class="text-muted text-sm leading-relaxed">{b.desc}</p>
            </div>
          </div>
        ))}
        <div class="border-t border-subtle"></div>
      </div>

    </div>
  </div>
</section>

---
const benefits = [
  { number: "01", title: "Diseño Estratégico",       desc: "Interfaces limpias y modernas que guían al usuario hacia la conversión." },
  { number: "02", title: "Copy de Conversión",        desc: "Textos persuasivos que conectan con los problemas reales de tu cliente." },
  { number: "03", title: "WhatsApp + Formulario",     desc: "Integraciones clave para que te contacten por su canal favorito." },
  { number: "04", title: "Entrega Llave en Mano",     desc: "Tu web lista para vender. Sin configuraciones técnicas de tu parte." },
  { number: "05", title: "Analítica Configurada",     desc: "Pixel de Facebook y Google Analytics 4 listos para tus campañas." },
  { number: "06", title: "Velocidad Máxima",          desc: "Optimizada para Core Web Vitals. Google y tus usuarios lo notan." }
];
---

<section id="ventajas" class="bg-ivory py-24 md:py-36 overflow-hidden">
  <div class="max-w-[1600px] mx-auto px-8 md:px-16 lg:px-28">

    <div class="grid md:grid-cols-2 gap-16 md:gap-24 items-start">

      <!-- Left sticky -->
      <div class="md:sticky md:top-32">
        <p class="label text-muted mb-4 reveal-fast">Ventajas</p>
        <h2 class="font-display italic font-black text-[clamp(2.5rem,_6vw,_5rem)] text-ink leading-[0.93] mb-8 reveal" style="transition-delay:0.1s">
          Por qué elegir<br>
          <span class="text-blue">Clickora.</span>
        </h2>
        <p class="text-muted text-sm leading-relaxed mb-10 max-w-sm reveal" style="transition-delay:0.2s">
          Cada detalle pensado para maximizar tus resultados desde el primer día.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 reveal" style="transition-delay:0.3s">
          <a
            href="https://wa.me/34608008081?text=Hola,%20quiero%20una%20consultoría%20gratuita"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary"
          >
            Consultoría gratis
          </a>
          <a href="mailto:info@clickora.es" class="btn-outline">
            Escríbenos
          </a>
        </div>
      </div>

      <!-- Right: numbered list -->
      <div>
        {benefits.map((b, i) => (
          <div
            class={`group flex items-start gap-5 py-7 border-b border-soft last:border-b-0 hover:bg-yellow/10 -mx-4 px-4 transition-colors duration-300 reveal`}
            style={`transition-delay:${i * 0.07}s`}
          >
            <span class="font-display italic font-black text-3xl text-blue/20 group-hover:text-blue transition-colors duration-300 leading-none w-12 flex-shrink-0 pt-1">
              {b.number}
            </span>
            <div>
              <h3 class="font-sans font-bold text-base text-ink mb-1.5 group-hover:text-blue transition-colors duration-300">
                {b.title}
              </h3>
              <p class="text-muted text-sm leading-relaxed">{b.desc}</p>
            </div>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>

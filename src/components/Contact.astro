---
---

<section id="contacto" class="bg-ink py-24 md:py-36 overflow-hidden">
  <div class="max-w-[1600px] mx-auto px-6 md:px-10 lg:px-16">

    <!-- Header -->
    <div class="mb-16 md:mb-20">
      <p class="label text-muted mb-4 reveal-fast">Contacto</p>
      <h2 class="heading-display font-serif text-[clamp(2.5rem,_6vw,_5.5rem)] text-parchment reveal" style="transition-delay:0.1s">
        Hablemos de tu<br>
        <em class="text-lime not-italic">proyecto.</em>
      </h2>
    </div>

    <div class="grid md:grid-cols-2 gap-px bg-subtle">

      <!-- Left: contact info -->
      <div class="bg-ink2 p-8 md:p-12 flex flex-col gap-10 reveal" style="transition-delay:0.1s">
        <div>
          <p class="text-muted text-sm leading-relaxed mb-6">
            Respondo en menos de 24 horas. La primera consultoría es gratuita y sin compromiso.
          </p>
          <p class="font-serif text-parchment text-2xl md:text-3xl">
            info@diegodpl.com
          </p>
        </div>

        <!-- Contact links -->
        <div class="flex flex-col gap-3">
          <a
            href="https://wa.me/34608008081"
            target="_blank"
            rel="noopener noreferrer"
            class="group flex items-center justify-between p-5 border border-subtle hover:border-lime transition-colors duration-300"
          >
            <div class="flex items-center gap-4">
              <svg class="w-5 h-5 text-muted group-hover:text-lime transition-colors" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              <div>
                <p class="label text-muted">WhatsApp</p>
                <p class="text-parchment text-sm font-medium">608 00 80 81</p>
              </div>
            </div>
            <svg class="w-4 h-4 text-muted group-hover:text-lime transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </a>

          <a
            href="tel:+34608008081"
            class="group flex items-center justify-between p-5 border border-subtle hover:border-lime transition-colors duration-300"
          >
            <div class="flex items-center gap-4">
              <svg class="w-5 h-5 text-muted group-hover:text-lime transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
              </svg>
              <div>
                <p class="label text-muted">Teléfono</p>
                <p class="text-parchment text-sm font-medium">608 00 80 81</p>
              </div>
            </div>
            <svg class="w-4 h-4 text-muted group-hover:text-lime transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </a>
        </div>

        <!-- Trust stat -->
        <div class="mt-auto pt-8 border-t border-subtle">
          <p class="font-serif text-[clamp(3rem,_6vw,_5rem)] text-lime leading-none">+8</p>
          <p class="label text-muted mt-2">Años creando webs que venden</p>
        </div>
      </div>

      <!-- Right: form -->
      <div class="bg-ink2 p-8 md:p-12 reveal" style="transition-delay:0.2s">
        <h3 class="font-serif text-2xl text-parchment mb-8">Envía un mensaje</h3>

        <form id="contact-form" class="flex flex-col gap-5">
          <div>
            <label for="name" class="label text-muted block mb-2">Nombre</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="input-field"
              placeholder="Tu nombre"
            />
          </div>

          <div>
            <label for="email" class="label text-muted block mb-2">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="input-field"
              placeholder="tu@email.com"
            />
          </div>

          <div>
            <label for="message" class="label text-muted block mb-2">Mensaje</label>
            <textarea
              id="message"
              name="message"
              required
              rows="5"
              class="input-field resize-none"
              placeholder="Cuéntame sobre tu proyecto..."
            ></textarea>
          </div>

          <button type="submit" class="btn-lime w-full justify-center mt-2">
            Enviar mensaje →
          </button>
        </form>

        <div id="form-message" class="mt-4 hidden p-4 border border-lime/20 text-lime text-sm"></div>
      </div>

    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const msg  = document.getElementById('form-message');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const wa = `*Nuevo contacto desde clickora.es*\n\n*Nombre:* ${data.get('name')}\n*Email:* ${data.get('email')}\n*Mensaje:* ${data.get('message')}`;
    window.open(`https://wa.me/34608008081?text=${encodeURIComponent(wa)}`, '_blank');
    if (msg) {
      msg.textContent = '¡Perfecto! Te redirigimos a WhatsApp para completar el envío.';
      msg.classList.remove('hidden');
      setTimeout(() => msg.classList.add('hidden'), 5000);
    }
    form.reset();
  });
</script>

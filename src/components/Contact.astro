---
---

<section id="contacto" class="relative py-20 md:py-32 overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0 bg-gradient-to-b from-slate-950 via-slate-900 to-slate-950"></div>
  <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-accent-500/10 rounded-full blur-3xl"></div>
  
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl mx-auto">
      <!-- Section Header -->
      <div class="text-center mb-12 space-y-4">
        <span class="inline-block px-4 py-2 rounded-full glass border border-brand-500/20 text-sm text-brand-400 font-semibold">
          Contacto
        </span>
        <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-white">
          Hablemos de tu <span class="gradient-text">proyecto</span>
        </h2>
        <p class="text-lg text-slate-400">
          Respondo en menos de 24 horas
        </p>
      </div>
      
      <div class="grid md:grid-cols-2 gap-8">
        <!-- Contact Info -->
        <div class="space-y-6">
          <div class="p-6 rounded-2xl glass border border-slate-800">
            <h3 class="text-xl font-bold text-white mb-6">Formas de contacto</h3>
            
            <div class="space-y-4">
              <!-- WhatsApp -->
              <a 
                href="https://wa.me/34608008081"
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-4 p-4 rounded-xl hover:bg-slate-800/50 transition-colors group"
              >
                <div class="w-12 h-12 rounded-lg bg-gradient-to-br from-green-500 to-green-600 flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform">
                  <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                  </svg>
                </div>
                <div class="flex-1">
                  <div class="text-sm text-slate-400">WhatsApp</div>
                  <div class="text-white font-semibold">608 00 80 81</div>
                </div>
                <svg class="w-5 h-5 text-slate-600 group-hover:text-green-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
              </a>
              
              <!-- Email -->
              <a 
                href="mailto:info@diegodpl.com"
                class="flex items-center gap-4 p-4 rounded-xl hover:bg-slate-800/50 transition-colors group"
              >
                <div class="w-12 h-12 rounded-lg bg-gradient-to-br from-brand-500 to-brand-600 flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform">
                  <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                  </svg>
                </div>
                <div class="flex-1">
                  <div class="text-sm text-slate-400">Email</div>
                  <div class="text-white font-semibold">info@diegodpl.com</div>
                </div>
                <svg class="w-5 h-5 text-slate-600 group-hover:text-brand-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
              </a>
              
              <!-- Phone -->
              <a 
                href="tel:+34608008081"
                class="flex items-center gap-4 p-4 rounded-xl hover:bg-slate-800/50 transition-colors group"
              >
                <div class="w-12 h-12 rounded-lg bg-gradient-to-br from-accent-500 to-accent-600 flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform">
                  <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                  </svg>
                </div>
                <div class="flex-1">
                  <div class="text-sm text-slate-400">Teléfono</div>
                  <div class="text-white font-semibold">608 00 80 81</div>
                </div>
                <svg class="w-5 h-5 text-slate-600 group-hover:text-accent-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
              </a>
            </div>
          </div>
          
          <!-- Trust Badge -->
          <div class="p-6 rounded-2xl glass border border-slate-800 text-center">
            <div class="text-4xl font-bold gradient-text mb-2">+8 años</div>
            <div class="text-slate-400">de experiencia en desarrollo web</div>
          </div>
        </div>
        
        <!-- Contact Form -->
        <div class="p-6 md:p-8 rounded-2xl glass border border-slate-800">
          <h3 class="text-xl font-bold text-white mb-6">Envía un mensaje</h3>
          
          <form id="contact-form" class="space-y-5">
            <div>
              <label for="name" class="block text-sm font-medium text-slate-300 mb-2">Nombre</label>
              <input 
                type="text" 
                id="name" 
                name="name" 
                required
                class="w-full px-4 py-3 rounded-lg bg-slate-900/50 border border-slate-700 text-white placeholder-slate-500 focus:outline-none focus:border-brand-500 transition-colors"
                placeholder="Tu nombre"
              />
            </div>
            
            <div>
              <label for="email" class="block text-sm font-medium text-slate-300 mb-2">Email</label>
              <input 
                type="email" 
                id="email" 
                name="email" 
                required
                class="w-full px-4 py-3 rounded-lg bg-slate-900/50 border border-slate-700 text-white placeholder-slate-500 focus:outline-none focus:border-brand-500 transition-colors"
                placeholder="tu@email.com"
              />
            </div>
            
            <div>
              <label for="message" class="block text-sm font-medium text-slate-300 mb-2">Mensaje</label>
              <textarea 
                id="message" 
                name="message" 
                required
                rows="4"
                class="w-full px-4 py-3 rounded-lg bg-slate-900/50 border border-slate-700 text-white placeholder-slate-500 focus:outline-none focus:border-brand-500 transition-colors resize-none"
                placeholder="Cuéntame sobre tu proyecto..."
              ></textarea>
            </div>
            
            <button 
              type="submit"
              class="w-full py-4 rounded-xl bg-gradient-to-r from-brand-500 to-accent-600 text-white font-bold shadow-lg shadow-brand-500/50 hover:shadow-xl hover:shadow-brand-500/70 transition-all duration-300 transform hover:scale-105"
            >
              Enviar Mensaje
            </button>
          </form>
          
          <div id="form-message" class="mt-4 hidden"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const messageDiv = document.getElementById('form-message');
  
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const formData = new FormData(form);
    const name = formData.get('name');
    const email = formData.get('email');
    const message = formData.get('message');
    
    // Create WhatsApp message
    const whatsappMessage = `*Nuevo contacto desde clickora.es*\n\n*Nombre:* ${name}\n*Email:* ${email}\n*Mensaje:* ${message}`;
    const whatsappUrl = `https://wa.me/34608008081?text=${encodeURIComponent(whatsappMessage)}`;
    
    // Open WhatsApp in new tab
    window.open(whatsappUrl, '_blank');
    
    // Show success message
    if (messageDiv) {
      messageDiv.className = 'mt-4 p-4 rounded-lg bg-green-500/10 border border-green-500/20 text-green-400 text-sm';
      messageDiv.textContent = '¡Mensaje enviado! Te redirigimos a WhatsApp...';
      messageDiv.classList.remove('hidden');
    }
    
    // Reset form
    form.reset();
    
    // Hide message after 5 seconds
    setTimeout(() => {
      messageDiv?.classList.add('hidden');
    }, 5000);
  });
</script>

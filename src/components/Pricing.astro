---
const plans = [
  {
    name: "Starter",
    price: "299",
    description: "Para validar tu oferta y empezar a captar leads.",
    features: [
      "Landing Page One-Page",
      "Diseño profesional",
      "Integración WhatsApp",
      "Formulario de contacto",
      "Adaptada a móviles",
      "Carga ultrarrápida",
      "Entrega en 2 semanas"
    ],
    highlighted: false
  },
  {
    name: "Growth",
    price: "499",
    description: "Para negocios que quieren escalar y medir resultados con exactitud.",
    features: [
      "Todo lo del Starter",
      "Copywriting persuasivo",
      "Pixel & Analytics listos",
      "SEO técnico optimizado",
      "Integración CRM básico",
      "Página de Gracias",
      "Entrega prioritaria"
    ],
    highlighted: true,
    badge: "Más popular"
  },
  {
    name: "Pro",
    price: "899",
    description: "La solución completa para marcas que compiten en alto nivel.",
    features: [
      "Todo lo del Growth",
      "Estrategia de conversión",
      "Diseño totalmente a medida",
      "A/B Testing en titulares",
      "Automatización de emails",
      "Soporte 30 días",
      "Revisión de campañas Ads"
    ],
    highlighted: false
  }
];
---

<section id="precios" class="bg-ivory py-24 md:py-36 overflow-hidden">
  <div class="max-w-[1600px] mx-auto px-8 md:px-16 lg:px-28">

    <!-- Header -->
    <div class="mb-16 md:mb-20">
      <p class="label text-muted mb-4 reveal-fast">Inversión</p>
      <h2 class="font-display italic font-black text-[clamp(2.5rem,_6vw,_5.5rem)] text-ink leading-[0.93] reveal" style="transition-delay:0.1s">
        Planes <span class="text-blue">claros.</span>
      </h2>
    </div>

    <!-- Plans grid -->
    <div class="grid md:grid-cols-3 gap-4">
      {plans.map((plan, i) => (
        <div
          class={`relative flex flex-col reveal ${plan.highlighted ? 'bg-blue' : 'bg-ivory2 border-2 border-soft hover:border-blue transition-colors duration-300'}`}
          style={`transition-delay:${i * 0.1}s`}
        >
          {plan.badge && (
            <div class="absolute -top-4 left-6">
              <span class="bg-yellow text-ink label px-4 py-1.5">{plan.badge}</span>
            </div>
          )}

          <div class="p-8 md:p-10 flex flex-col gap-8 flex-1">

            <!-- Name + price -->
            <div>
              {plan.badge && <div class="h-4"></div>}
              <h3 class={`font-sans font-extrabold text-2xl mb-2 ${plan.highlighted ? 'text-ivory' : 'text-ink'}`}>
                {plan.name}
              </h3>
              <p class={`text-sm mb-6 leading-relaxed ${plan.highlighted ? 'text-ivory/60' : 'text-muted'}`}>
                {plan.description}
              </p>
              <div class="flex items-baseline gap-1">
                <span class={`font-display italic font-black text-[clamp(3rem,_5vw,_4rem)] leading-none ${plan.highlighted ? 'text-yellow' : 'text-blue'}`}>
                  {plan.price}€
                </span>
                <span class={`text-xs ${plan.highlighted ? 'text-ivory/50' : 'text-muted'}`}>+ IVA · pago único</span>
              </div>
            </div>

            <!-- Divider -->
            <div class={`h-px ${plan.highlighted ? 'bg-ivory/15' : 'bg-soft'}`}></div>

            <!-- Features -->
            <ul class="flex-1 space-y-3">
              {plan.features.map(f => (
                <li class={`flex items-start gap-3 text-sm ${plan.highlighted ? 'text-ivory/75' : 'text-ink/70'}`}>
                  <span class={`w-1.5 h-1.5 rounded-full flex-shrink-0 mt-1.5 ${plan.highlighted ? 'bg-yellow' : 'bg-blue'}`}></span>
                  {f}
                </li>
              ))}
            </ul>

            <!-- CTA -->
            <a
              href={`https://wa.me/34608008081?text=Hola,%20me%20interesa%20el%20Plan%20${plan.name}`}
              target="_blank"
              rel="noopener noreferrer"
              class={plan.highlighted ? 'btn-outline-white justify-center' : 'btn-outline justify-center'}
            >
              {plan.name === 'Starter' ? 'Empezar →' : plan.name === 'Growth' ? 'Elegir Growth →' : 'Hablar con Diego →'}
            </a>
          </div>
        </div>
      ))}
    </div>

    <!-- Maintenance -->
    <div class="mt-4 bg-ink p-8 md:p-10 reveal" style="transition-delay:0.35s">
      <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-8">
        <div>
          <p class="label text-yellow mb-3">Complemento opcional</p>
          <h3 class="font-sans font-extrabold text-2xl text-ivory mb-2">Mantenimiento VIP</h3>
          <p class="text-ivory/60 text-sm leading-relaxed max-w-xl">
            Por <strong class="text-ivory">49€/mes</strong> nos encargamos del hosting, dominio, seguridad y actualizaciones de texto. Sin permanencia.
          </p>
          <div class="flex flex-wrap gap-6 mt-4 text-xs text-ivory/40">
            <span class="flex items-center gap-1.5"><span class="w-1.5 h-1.5 bg-yellow"></span>Hosting incluido</span>
            <span class="flex items-center gap-1.5"><span class="w-1.5 h-1.5 bg-yellow"></span>Copias diarias</span>
            <span class="flex items-center gap-1.5"><span class="w-1.5 h-1.5 bg-yellow"></span>Sin permanencia</span>
          </div>
        </div>
        <a
          href="https://wa.me/34608008081?text=Hola,%20me%20interesa%20el%20mantenimiento"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-outline-white flex-shrink-0"
        >
          Saber más
        </a>
      </div>
    </div>

  </div>
</section>

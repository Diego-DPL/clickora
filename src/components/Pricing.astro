---
const plans = [
  {
    name: 'Plan Starter',
    price: '299',
    description: 'Ideal para validar tu oferta y empezar a captar leads (WhatsApp/Formulario).',
    features: [
      'Landing Page One-Page',
      'Diseño limpio y profesional',
      'Integración WhatsApp',
      'Formulario de contacto',
      'Adaptada a móviles',
      'Carga rápida',
      'Entrega en 2 semanas'
    ],
    cta: 'Empezar ahora',
    highlighted: false
  },
  {
    name: 'Plan Growth',
    price: '499',
    description: 'Para negocios que buscan escalar y medir resultados con exactitud.',
    features: [
      'Todo lo del Plan Starter',
      'Copywriting persuasivo',
      'Configuración Pixel & Analytics',
      'SEO Técnico optimizado',
      'Integración con CRM básico',
      'Página de "Gracias" (para medir)',
      'Entrega prioritaria'
    ],
    cta: 'Elegir Plan Growth',
    highlighted: true,
    badge: 'Más Popular'
  },
  {
    name: 'Plan Pro',
    price: '899',
    description: 'La solución completa para marcas que compiten en alto nivel.',
    features: [
      'Todo lo del Plan Growth',
      'Estrategia completa de conversión',
      'Diseño totalmente a medida',
      'A/B Testing en titulares',
      'Automatización de emails básica',
      'Soporte post-lanzamiento (30 días)',
      'Revisión de campañas Ads'
    ],
    cta: 'Hablar con un experto',
    highlighted: false
  }
];
---

<section id="precios" class="relative py-20 md:py-32 overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0 bg-slate-950"></div>
  <div class="absolute top-1/2 left-1/2 w-[800px] h-[800px] bg-brand-500/5 rounded-full blur-3xl transform -translate-x-1/2 -translate-y-1/2"></div>
  
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-16 space-y-4">
      <span class="inline-block px-4 py-2 rounded-full glass border border-brand-500/20 text-sm text-brand-400 font-semibold">
        Planes Claros
      </span>
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-white">
        Inversión <span class="gradient-text">Inteligente</span>
      </h2>
      <p class="max-w-2xl mx-auto text-lg text-slate-400">
        Elige el plan que mejor se adapte a la etapa actual de tu negocio.
      </p>
    </div>
    
    <!-- Pricing Cards -->
    <div class="grid md:grid-cols-3 gap-8 max-w-7xl mx-auto mb-20">
      {plans.map((plan, index) => (
        <div 
          class={`relative p-8 rounded-3xl border transition-all duration-500 transform hover:-translate-y-2 flex flex-col ${
            plan.highlighted 
              ? 'glass border-brand-500 shadow-2xl shadow-brand-500/20' 
              : 'glass border-slate-800 hover:border-slate-700'
          }`}
          style={`animation: fadeInScale 0.6s ease-out ${index * 0.2}s forwards; opacity: 0;`}
        >
          {plan.badge && (
            <div class="absolute -top-4 left-1/2 transform -translate-x-1/2 z-10 w-max">
              <span class="px-6 py-2 rounded-full bg-gradient-to-r from-brand-500 to-brand-600 text-white text-sm font-bold shadow-lg flex items-center gap-2">
                <span class="animate-pulse">🔥</span> {plan.badge}
              </span>
            </div>
          )}
          
          <div class="space-y-6 flex-1">
            <!-- Header -->
            <div class="space-y-2">
              <h3 class="text-2xl font-bold text-white">{plan.name}</h3>
              <p class="text-slate-400 text-sm h-10">{plan.description}</p>
            </div>
            
            <!-- Price -->
            <div class="space-y-1">
              <div class="flex items-baseline gap-2">
                <span class="text-4xl font-bold text-white">{plan.price}€</span>
                <span class="text-slate-500">/pago único</span>
              </div>
              <p class="text-xs text-slate-500">+ IVA</p>
            </div>
            
            <!-- Features -->
            <ul class="space-y-4">
              {plan.features.map(feature => (
                <li class="flex items-start gap-3 text-sm text-slate-300">
                  <svg class="w-5 h-5 text-brand-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                  </svg>
                  <span>{feature}</span>
                </li>
              ))}
            </ul>
          </div>
          
          <!-- CTA -->
          <div class="pt-8 mt-auto">
            <a 
              href={`https://wa.me/34608008081?text=Hola,%20me%20interesa%20el%20${plan.name}`}
              target="_blank"
              rel="noopener noreferrer"
              class={`block w-full py-4 rounded-xl text-center font-bold text-lg transition-all duration-300 ${
                plan.highlighted 
                  ? 'bg-brand-500 text-white hover:bg-brand-600 shadow-lg shadow-brand-500/25' 
                  : 'bg-slate-800 text-white hover:bg-slate-700 border border-slate-700'
              }`}
            >
              {plan.cta}
            </a>
          </div>
        </div>
      ))}
    </div>

    <!-- Maintenance Section -->
    <div class="max-w-4xl mx-auto rounded-3xl glass border border-slate-800 p-8 md:p-12 relative overflow-hidden">
        <div class="absolute top-0 right-0 p-12 opacity-5 pointer-events-none">
            <svg class="w-64 h-64 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/></svg>
        </div>
        
        <div class="relative z-10 flex flex-col md:flex-row items-center gap-8 md:gap-12">
            <div class="flex-1 space-y-4 text-center md:text-left">
                <h3 class="text-2xl font-bold text-white">¿Necesitas Mantenimiento?</h3>
                <p class="text-slate-400">
                    El mantenimiento es <span class="text-brand-400 font-semibold">opcional pero muy recomendado</span>. 
                    Por 49€/mes nos encargamos del hosting, dominio, seguridad y textos, para que tú solo te preocupes de vender.
                </p>
                <div class="flex flex-wrap gap-4 justify-center md:justify-start text-sm text-slate-500">
                    <span class="flex items-center gap-1">✅ Hosting Incluido</span>
                    <span class="flex items-center gap-1">✅ Copias diarias</span>
                    <span class="flex items-center gap-1">✅ Sin permanencia</span>
                </div>
            </div>
            <div class="flex-shrink-0">
                <a href="https://wa.me/34608008081?text=Hola,%20me%20interesa%20el%20mantenimiento" class="inline-block px-8 py-4 rounded-xl border border-slate-600 text-white hover:bg-slate-800 transition-colors">
                    Saber más
                </a>
            </div>
        </div>
    </div>
  </div>
</section>

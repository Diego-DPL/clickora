---
const plans = [
  {
    name: 'Landing Page Premium',
    price: '299',
    originalPrice: '700',
    description: 'Oferta Especial: Web de alto impacto valorada en 700€',
    features: [
      'Landing Page',
      'Diseño UI premium futurista',
      'Copywriting persuasivo',
      'Formulario + WhatsApp',
      'Integración Pixel & Analytics',
      'Hosting y dominio incluido',
      'Optimización de velocidad extrema',
      'SEO Técnico avanzado',
      'Adaptada a móviles (Responsive)',
      'Entrega prioritaria'
    ],
    cta: 'Aprovechar Oferta',
    highlighted: true,
    badge: 'Oferta Irresistible'
  },
  {
    name: 'Mantenimiento VIP',
    price: '49',
    originalPrice: '150',
    period: '/mes',
    description: 'Tu negocio siempre seguro y actualizado',
    features: [
      'Cambios de contenido ilimitados',
      'Actualizaciones de seguridad',
      'Optimización continua',
      'Reportes mensuales de rendimiento',
      'Soporte prioritario por WhatsApp',
      'Copias de seguridad diarias',
      'Monitoreo 24/7',
      'Mejoras de velocidad',
      'Consultoría de crecimiento',
      'Sin permanencia'
    ],
    cta: 'Asegurar mi Web',
    highlighted: false
  }
];
---

<section id="precios" class="relative py-20 md:py-32 overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0 bg-slate-950"></div>
  <div class="absolute top-1/2 left-1/2 w-[800px] h-[800px] bg-brand-500/5 rounded-full blur-3xl transform -translate-x-1/2 -translate-y-1/2"></div>
  
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-16 space-y-4">
      <span class="inline-block px-4 py-2 rounded-full glass border border-brand-500/20 text-sm text-brand-400 font-semibold">
        Oferta Limitada
      </span>
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-white">
        Inversión <span class="gradient-text">Inteligente</span>
      </h2>
      <p class="max-w-2xl mx-auto text-lg text-slate-400">
        Precios diseñados para darte el máximo retorno de inversión (ROI).
      </p>
    </div>
    
    <!-- Pricing Cards -->
    <div class="grid md:grid-cols-2 gap-8 max-w-5xl mx-auto">
      {plans.map((plan, index) => (
        <div 
          class={`relative p-8 md:p-10 rounded-3xl border transition-all duration-500 transform hover:-translate-y-2 ${
            plan.highlighted 
              ? 'glass border-brand-500 shadow-2xl shadow-brand-500/20' 
              : 'glass border-slate-800 hover:border-slate-700'
          }`}
          style={`animation: fadeInScale 0.6s ease-out ${index * 0.2}s forwards; opacity: 0;`}
        >
          {plan.badge && (
            <div class="absolute -top-4 left-1/2 transform -translate-x-1/2 z-10 w-max">
              <span class="px-6 py-2 rounded-full bg-gradient-to-r from-red-500 to-pink-600 text-white text-sm font-bold shadow-lg flex items-center gap-2">
                <span class="animate-pulse">🔥</span> {plan.badge}
              </span>
            </div>
          )}
          
          <div class="space-y-6">
            <!-- Header -->
            <div class="space-y-2">
              <h3 class="text-2xl font-bold text-white">{plan.name}</h3>
              <p class="text-slate-400 text-sm">{plan.description}</p>
            </div>
            
            <!-- Price -->
            <div class="space-y-1">
              {plan.originalPrice && (
                <div class="text-slate-500 text-lg line-through font-medium">
                  Valorado en {plan.originalPrice}€
                </div>
              )}
              <div class="flex items-baseline gap-2">
                {!plan.originalPrice && <span class="text-sm text-slate-400">Desde</span>}
                <span class="text-5xl font-bold gradient-text">{plan.price}€</span>
                {plan.period && <span class="text-xl text-slate-400">{plan.period}</span>}
              </div>
            </div>
            
            <!-- Features -->
            <ul class="space-y-4 py-6">
              {plan.features.map(feature => (
                <li class="flex items-start gap-3">
                  <svg class="w-6 h-6 text-green-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                  </svg>
                  <span class="text-slate-300">{feature}</span>
                </li>
              ))}
            </ul>
            
            <!-- CTA Button -->
            <a 
              href="https://wa.me/34608008081?text=Hola,%20quiero%20información%20sobre%20el%20plan%20{plan.name}"
              target="_blank"
              rel="noopener noreferrer"
              class={`block w-full py-4 rounded-xl text-center font-bold transition-all duration-300 transform hover:scale-105 ${
                plan.highlighted
                  ? 'bg-gradient-to-r from-brand-500 to-accent-600 text-white shadow-lg shadow-brand-500/50 hover:shadow-xl hover:shadow-brand-500/70'
                  : 'glass border border-slate-700 text-white hover:border-brand-500/50 hover:bg-slate-800/50'
              }`}
            >
              {plan.cta}
            </a>
          </div>
        </div>
      ))}
    </div>
    
    <!-- Extra Info -->
    <div class="mt-16 text-center">
      <div class="inline-flex items-center gap-2 px-6 py-3 rounded-full glass border border-slate-800">
        <svg class="w-5 h-5 text-brand-500" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"></path>
        </svg>
        <span class="text-sm text-slate-400">¿Necesitas algo personalizado? <a href="#contacto" class="text-brand-400 hover:text-brand-300 font-semibold">Hablemos</a></span>
      </div>
    </div>
  </div>
</section>

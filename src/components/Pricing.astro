---
const plans = [
  {
    name: "Starter",
    price: "299",
    description: "Para validar tu oferta y empezar a captar leads.",
    features: [
      "Landing Page One-Page",
      "Diseño profesional",
      "Integración WhatsApp",
      "Formulario de contacto",
      "Adaptada a móviles",
      "Carga ultrarrápida",
      "Entrega en 2 semanas"
    ],
    highlighted: false
  },
  {
    name: "Growth",
    price: "499",
    description: "Para negocios que quieren escalar y medir resultados.",
    features: [
      "Todo lo del Starter",
      "Copywriting persuasivo",
      "Pixel & Analytics configurados",
      "SEO técnico optimizado",
      "Integración CRM básico",
      "Página de Gracias",
      "Entrega prioritaria"
    ],
    highlighted: true,
    badge: "Más popular"
  },
  {
    name: "Pro",
    price: "899",
    description: "La solución completa para marcas que compiten en alto nivel.",
    features: [
      "Todo lo del Growth",
      "Estrategia completa de conversión",
      "Diseño totalmente a medida",
      "A/B Testing en titulares",
      "Automatización de emails",
      "Soporte 30 días post-lanzamiento",
      "Revisión de campañas Ads"
    ],
    highlighted: false
  }
];
---

<section id="precios" class="bg-ink py-24 md:py-36 overflow-hidden">
  <div class="max-w-[1600px] mx-auto px-6 md:px-10 lg:px-16">

    <!-- Header -->
    <div class="mb-16 md:mb-20">
      <p class="label text-muted mb-4 reveal-fast">Inversión</p>
      <h2 class="heading-display font-serif text-[clamp(2.5rem,_6vw,_5.5rem)] text-parchment reveal" style="transition-delay:0.1s">
        Planes <em class="text-lime not-italic">claros.</em>
      </h2>
    </div>

    <!-- Pricing grid -->
    <div class="grid md:grid-cols-3 gap-px bg-subtle">
      {plans.map((plan, i) => (
        <div
          class={`relative flex flex-col p-8 md:p-10 reveal ${plan.highlighted ? 'bg-lime' : 'bg-ink2 hover:bg-ink3 transition-colors duration-300'}`}
          style={`transition-delay:${i * 0.12}s`}
        >
          {plan.badge && (
            <div class="mb-6">
              <span class="label text-ink bg-ink/10 px-3 py-1">
                {plan.badge}
              </span>
            </div>
          )}

          {!plan.badge && <div class="mb-6 h-6"></div>}

          <!-- Plan name & price -->
          <div class="mb-8">
            <h3 class={`font-serif text-2xl mb-2 ${plan.highlighted ? 'text-ink' : 'text-parchment'}`}>
              {plan.name}
            </h3>
            <p class={`text-sm mb-6 leading-relaxed ${plan.highlighted ? 'text-ink/70' : 'text-muted'}`}>
              {plan.description}
            </p>
            <div class="flex items-baseline gap-1">
              <span class={`font-serif text-[clamp(3rem,_6vw,_4.5rem)] leading-none ${plan.highlighted ? 'text-ink' : 'text-parchment'}`}>
                {plan.price}€
              </span>
              <span class={`text-xs ${plan.highlighted ? 'text-ink/60' : 'text-muted'}`}>+ IVA</span>
            </div>
          </div>

          <!-- Features -->
          <ul class="flex-1 mb-10 space-y-3">
            {plan.features.map(f => (
              <li class={`flex items-start gap-3 text-sm ${plan.highlighted ? 'text-ink/80' : 'text-muted'}`}>
                <span class={`w-1.5 h-1.5 rounded-full flex-shrink-0 mt-1.5 ${plan.highlighted ? 'bg-ink' : 'bg-lime'}`}></span>
                {f}
              </li>
            ))}
          </ul>

          <!-- CTA -->
          <a
            href={`https://wa.me/34608008081?text=Hola,%20me%20interesa%20el%20Plan%20${plan.name}`}
            target="_blank"
            rel="noopener noreferrer"
            class={plan.highlighted
              ? 'btn-lime bg-ink text-parchment hover:bg-ink3 flex items-center justify-center w-full'
              : 'btn-ghost flex items-center justify-center w-full'}
          >
            {plan.highlighted ? 'Elegir Growth →' : (plan.name === 'Starter' ? 'Empezar →' : 'Hablar con Diego →')}
          </a>
        </div>
      ))}
    </div>

    <!-- Maintenance add-on -->
    <div class="mt-px bg-ink2 hover:bg-ink3 transition-colors duration-300 reveal" style="transition-delay:0.4s">
      <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-8 p-8 md:p-10">
        <div class="flex-1">
          <p class="label text-lime mb-3">Complemento opcional</p>
          <h3 class="font-serif text-2xl text-parchment mb-2">Mantenimiento VIP</h3>
          <p class="text-muted text-sm leading-relaxed max-w-xl">
            Por <strong class="text-parchment">49€/mes</strong> nos encargamos del hosting, dominio, seguridad y actualizaciones de texto. Sin permanencia.
          </p>
          <div class="flex flex-wrap gap-6 mt-4 text-xs text-muted">
            <span class="flex items-center gap-1.5"><span class="w-1.5 h-1.5 rounded-full bg-lime"></span>Hosting incluido</span>
            <span class="flex items-center gap-1.5"><span class="w-1.5 h-1.5 rounded-full bg-lime"></span>Copias diarias</span>
            <span class="flex items-center gap-1.5"><span class="w-1.5 h-1.5 rounded-full bg-lime"></span>Sin permanencia</span>
          </div>
        </div>
        <a
          href="https://wa.me/34608008081?text=Hola,%20me%20interesa%20el%20mantenimiento"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-ghost flex-shrink-0"
        >
          Saber más
        </a>
      </div>
    </div>

  </div>
</section>

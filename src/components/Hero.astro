---
---

<section id="hero" class="relative min-h-screen bg-ivory flex flex-col justify-between overflow-hidden pt-20">

  <!-- Vertical text left (desktop only) -->
  <div class="hidden lg:flex absolute left-6 top-1/2 -translate-y-1/2 z-10">
    <p class="label text-muted" style="writing-mode: vertical-rl; transform: rotate(180deg); letter-spacing: 0.25em;">
      Landing Pages · Diseño Web · España
    </p>
  </div>

  <!-- Rotating badge (desktop only) -->
  <div class="hidden md:block absolute top-28 right-8 lg:right-16 z-10 badge-spin w-28 h-28 lg:w-36 lg:h-36" aria-hidden="true">
    <svg viewBox="0 0 120 120" class="w-full h-full">
      <defs>
        <path id="badge-circle" d="M60,60 m-46,0 a46,46 0 1,1 92,0 a46,46 0 1,1 -92,0"/>
      </defs>
      <text fill="#0032FF" style="font-size:9px; font-family:'Syne',sans-serif; font-weight:800; letter-spacing:3.5px;">
        <textPath href="#badge-circle">★ DISEÑO · WEB · CONVERSIÓN · VENTA ·</textPath>
      </text>
    </svg>
  </div>

  <!-- Main content -->
  <div class="flex-1 flex items-center">
    <div class="max-w-[1600px] mx-auto w-full px-8 md:px-16 lg:px-28">

      <!-- Label -->
      <p class="label text-muted mb-8 lg:mb-12 reveal-fast">
        Estudio de diseño web · +8 años de experiencia
      </p>

      <!-- Giant headline — mixed weights and families -->
      <h1 class="relative">
        <!-- Line 1: Fraunces italic light -->
        <span class="block font-display italic font-light text-[clamp(3rem,_8vw,_7.5rem)] leading-[1] text-ink reveal" style="transition-delay:0.05s">
          Diseñamos
        </span>

        <!-- Line 2: Syne Black + Fraunces italic — overlapping feel -->
        <span class="block font-sans font-extrabold text-[clamp(3.5rem,_10vw,_9.5rem)] leading-[0.9] text-ink reveal" style="transition-delay:0.12s">
          páginas web
        </span>

        <!-- Line 3: "que" small + "VENDEN." large display in blue -->
        <span class="block reveal" style="transition-delay:0.2s">
          <span class="font-display italic font-light text-[clamp(2rem,_5vw,_4.5rem)] text-muted">que</span>
          <span class="font-display italic font-black text-[clamp(3.5rem,_10vw,_9.5rem)] leading-[0.9] text-blue ml-2 md:ml-4">
            <span class="highlight">venden.</span>
          </span>
        </span>
      </h1>

      <!-- Subtext + CTAs -->
      <div class="mt-12 lg:mt-16 flex flex-col md:flex-row items-start gap-8 md:gap-16 reveal" style="transition-delay:0.3s">
        <p class="text-muted text-base leading-relaxed max-w-sm">
          Diseño estratégico + desarrollo ultrarrápido + medición configurada. Tu web lista para convertir desde el día&nbsp;1.
        </p>
        <div class="flex flex-col sm:flex-row items-start gap-4">
          <a
            href="https://wa.me/34608008081?text=Hola,%20quiero%20una%20propuesta%20para%20mi%20web"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Pedir propuesta
          </a>
          <a href="#ejemplos" class="btn-outline">Ver trabajo ↓</a>
        </div>
      </div>

    </div>
  </div>

  <!-- Stats bar -->
  <div class="border-t border-soft">
    <div class="max-w-[1600px] mx-auto px-8 md:px-16 lg:px-28 py-6">
      <div class="flex flex-wrap gap-8 md:gap-16 reveal-fast" style="transition-delay:0.4s">
        <div>
          <span class="font-display italic font-black text-3xl text-blue">+8</span>
          <span class="label text-muted ml-2">Años de experiencia</span>
        </div>
        <div>
          <span class="font-display italic font-black text-3xl text-blue">30+</span>
          <span class="label text-muted ml-2">Proyectos entregados</span>
        </div>
        <div>
          <span class="font-display italic font-black text-3xl text-blue">2–4</span>
          <span class="label text-muted ml-2">Semanas de entrega</span>
        </div>
        <div>
          <span class="font-display italic font-black text-3xl text-blue">100%</span>
          <span class="label text-muted ml-2">Satisfacción garantizada</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Yellow ticker -->
  <div class="overflow-hidden bg-yellow py-3 select-none">
    <div class="marquee-track whitespace-nowrap">
      {Array.from({ length: 2 }).map(() => (
        <span class="inline-flex items-center gap-6 text-ink font-bold text-sm tracking-[0.15em] uppercase pr-6">
          <span>Landing Pages</span><span class="opacity-30">·</span>
          <span>Diseño Web</span><span class="opacity-30">·</span>
          <span>Conversión</span><span class="opacity-30">·</span>
          <span>SEO</span><span class="opacity-30">·</span>
          <span>E-commerce</span><span class="opacity-30">·</span>
          <span>Resultados Reales</span><span class="opacity-30">·</span>
          <span>España</span><span class="opacity-30">·</span>
          <span>Desarrollo Ultrarrápido</span><span class="opacity-30">·</span>
        </span>
      ))}
    </div>
  </div>

</section>

---
---

<section id="hero" class="relative min-h-screen flex flex-col justify-between overflow-hidden bg-ink">

  <!-- Content wrapper -->
  <div class="flex-1 flex flex-col justify-center pt-32 pb-0 px-6 md:px-10 lg:px-16 max-w-[1600px] mx-auto w-full">

    <!-- Upper: label + headline -->
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-8 md:gap-16">

      <!-- Headline block -->
      <div class="flex-1">
        <p class="label text-muted mb-8 md:mb-12 reveal reveal-fast">
          Diseño &amp; Desarrollo Web · España
        </p>
        <h1 class="heading-display font-serif text-[clamp(3.6rem,_9.5vw,_9.5rem)] text-parchment leading-[0.9] reveal" style="transition-delay:0.1s">
          Páginas<br>
          web que<br>
          <em class="text-lime not-italic">venden.</em>
        </h1>
      </div>

      <!-- Right column: tagline + scroll hint -->
      <div class="md:max-w-xs lg:max-w-sm flex flex-col gap-6 md:pb-4 reveal" style="transition-delay:0.25s">
        <p class="text-muted text-sm leading-relaxed">
          Diseño estratégico, desarrollo ultrarrápido y medición configurada desde el día&nbsp;1. Para negocios que quieren resultados reales.
        </p>
        <div class="flex items-center gap-3">
          <span class="inline-block w-8 h-px bg-lime"></span>
          <span class="label text-muted">Scroll para descubrir</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom bar: CTA + stats -->
  <div class="border-t border-subtle mt-12">
    <div class="max-w-[1600px] mx-auto w-full px-6 md:px-10 lg:px-16 py-8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-8">

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 reveal-fast" style="transition-delay:0.35s">
        <a
          href="https://wa.me/34608008081?text=Hola,%20quiero%20una%20propuesta%20para%20mi%20web"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-lime"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Pedir Propuesta
        </a>
        <a href="#ejemplos" class="btn-ghost">Ver Trabajo</a>
      </div>

      <!-- Stats -->
      <div class="flex gap-10 sm:gap-16 reveal-fast" style="transition-delay:0.45s">
        <div>
          <div class="font-serif text-[clamp(2rem,_5vw,_3.5rem)] text-lime leading-none">+8</div>
          <div class="label text-muted mt-1">Años de experiencia</div>
        </div>
        <div>
          <div class="font-serif text-[clamp(2rem,_5vw,_3.5rem)] text-lime leading-none">30+</div>
          <div class="label text-muted mt-1">Proyectos entregados</div>
        </div>
        <div>
          <div class="font-serif text-[clamp(2rem,_5vw,_3.5rem)] text-lime leading-none">2-4</div>
          <div class="label text-muted mt-1">Semanas de entrega</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Marquee ticker -->
  <div class="overflow-hidden bg-lime py-3 select-none">
    <div class="marquee-track whitespace-nowrap">
      {Array.from({ length: 2 }).map(() => (
        <span class="inline-flex items-center gap-6 text-ink font-bold text-sm tracking-widest uppercase pr-6">
          <span>Landing Pages</span>
          <span class="opacity-40">·</span>
          <span>Diseño Web</span>
          <span class="opacity-40">·</span>
          <span>Conversión</span>
          <span class="opacity-40">·</span>
          <span>SEO</span>
          <span class="opacity-40">·</span>
          <span>E-commerce</span>
          <span class="opacity-40">·</span>
          <span>Resultados Reales</span>
          <span class="opacity-40">·</span>
          <span>España</span>
          <span class="opacity-40">·</span>
          <span>Desarrollo Ultrarrápido</span>
          <span class="opacity-40">·</span>
        </span>
      ))}
    </div>
  </div>
</section>

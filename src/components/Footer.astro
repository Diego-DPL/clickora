---
---

<footer class="bg-ivory border-t border-soft overflow-hidden">

  <!-- Giant wordmark -->
  <div class="overflow-hidden border-b border-soft">
    <div class="px-8 md:px-16 lg:px-28 pt-16 md:pt-24 pb-0">
      <h2
        class="font-display italic font-black text-[clamp(5rem,_20vw,_20rem)] leading-none select-none tracking-tight whitespace-nowrap"
        style="color: rgba(15,15,15,0.05)"
        aria-hidden="true"
      >
        Clickora
      </h2>
    </div>
  </div>

  <!-- Links -->
  <div class="max-w-[1600px] mx-auto px-8 md:px-16 lg:px-28 py-16">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-10 mb-16">

      <div class="col-span-2 md:col-span-1">
        <p class="font-sans font-bold text-xl text-ink mb-3">
          Clickora<span class="text-blue">™</span>
        </p>
        <p class="text-muted text-sm leading-relaxed max-w-xs">
          Desarrollo web que convierte visitantes en clientes. España.
        </p>
      </div>

      <div>
        <p class="label text-muted mb-5">Navegación</p>
        <nav class="flex flex-col gap-3">
          <a href="#servicios" class="text-ink/50 hover:text-blue text-sm transition-colors">Servicios</a>
          <a href="#ventajas"  class="text-ink/50 hover:text-blue text-sm transition-colors">Ventajas</a>
          <a href="#precios"   class="text-ink/50 hover:text-blue text-sm transition-colors">Precios</a>
          <a href="#contacto"  class="text-ink/50 hover:text-blue text-sm transition-colors">Contacto</a>
        </nav>
      </div>

      <div>
        <p class="label text-muted mb-5">Legal</p>
        <nav class="flex flex-col gap-3">
          <a href="/aviso-legal" class="text-ink/50 hover:text-blue text-sm transition-colors">Aviso Legal</a>
          <a href="/privacidad"  class="text-ink/50 hover:text-blue text-sm transition-colors">Privacidad</a>
          <a href="/cookies"     class="text-ink/50 hover:text-blue text-sm transition-colors">Cookies</a>
        </nav>
      </div>

      <div>
        <p class="label text-muted mb-5">Contacto</p>
        <div class="flex flex-col gap-3">
          <a href="https://wa.me/34608008081" target="_blank" rel="noopener noreferrer"
             class="text-ink/50 hover:text-blue text-sm transition-colors">608 00 80 81</a>
          <a href="mailto:info@clickora.es"
             class="text-ink/50 hover:text-blue text-sm transition-colors">info@clickora.es</a>
        </div>
      </div>
    </div>

    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 pt-8 border-t border-soft">
      <p class="label text-muted">© 2026 Clickora. Todos los derechos reservados.</p>
      <p class="label text-muted">Hecho con obsesión por Diego DPL</p>
    </div>
  </div>
</footer>

